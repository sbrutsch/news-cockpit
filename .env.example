# News-Cockpit — Vorlage für lokale Entwicklung.
# Kopieren nach .env (liegt in .gitignore) und Werte setzen.
# In Produktion (Coolify) werden diese Variablen in der Coolify-UI gepflegt,
# NIE in Dateien im Repo (Governance-Regel 3).

# Datenbank: ohne Angabe lokal SQLite unter data/news.db
# Produktion: postgresql://benutzer:passwort@host:5432/newscockpit
DATABASE_URL=sqlite:///data/news.db

# Login-Passwort — bevorzugt als Hash (erzeugen: python scripts/make_password_hash.py)
# APP_PASSWORD_HASH=pbkdf2_sha256$600000$...
APP_PASSWORD=hier-aendern

# Token für POST /api/ingest (n8n / claude.ai-Routine), z. B. 48 Zufallszeichen
INGEST_TOKEN=hier-aendern

# Signiert Session-Cookies; ohne Angabe überleben Sessions keinen Neustart
SECRET_KEY=hier-aendern

HOST=127.0.0.1
PORT=8100
